# Copier ce fichier en .env et remplir les valeurs

# Base de données PostgreSQL
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/inspectflow

# Port du serveur Express
PORT=3001

# Supabase — uniquement pour le stockage fichiers (photos/docs) dans dashboard.html
# Peut être omis si le stockage est migré vers le VPS
VITE_SUPABASE_URL=https://xxx.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=eyJ...
